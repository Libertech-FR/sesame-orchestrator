<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{#if subject}}{{subject}}{{else}}Notification{{/if}}</title>
  </head>
  <body style="margin:0;padding:0;background:#f7fafc;font-family:Arial,Helvetica,sans-serif;color:#111;">
    <div style="max-width:640px;margin:0 auto;padding:24px;">
      <div style="background:#ffffff;border:1px solid #e6e8ef;border-radius:10px;padding:22px;">
        <div style="font-size:16px;font-weight:700;margin-bottom:10px;">
          {{#if title}}{{title}}{{else}}Notification{{/if}}
        </div>

        <div style="font-size:14px;line-height:1.6;color:#333;">
          {{#if message}}{{message}}{{else}}Bonjour, ceci est un exemple de mail template personnalisable.{{/if}}
        </div>

        {{#if ctaUrl}}
          <div style="margin-top:18px;">
            <a href="{{ctaUrl}}" style="display:inline-block;background:#1a7f37;color:#fff;text-decoration:none;padding:10px 14px;border-radius:8px;font-size:14px;">
              {{#if ctaLabel}}{{ctaLabel}}{{else}}Ouvrir{{/if}}
            </a>
          </div>
        {{/if}}

        <div style="margin-top:18px;font-size:12px;color:#666;">
          Destinataire : {{#if identity.inetOrgPerson.mail}}{{identity.inetOrgPerson.mail}}{{else}}(inconnu){{/if}} — Compte : {{identity.inetOrgPerson.uid}}
        </div>
      </div>
    </div>
  </body>
</html>

