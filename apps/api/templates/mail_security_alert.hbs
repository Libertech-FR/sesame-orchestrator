<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alerte sécurité</title>
  </head>
  <body style="margin:0;padding:0;background:#fff5f5;font-family:Arial,Helvetica,sans-serif;color:#111;">
    <div style="max-width:640px;margin:0 auto;padding:24px;">
      <div style="background:#ffffff;border:1px solid #ffd2d2;border-radius:10px;padding:22px;">
        <div style="font-size:18px;font-weight:700;margin-bottom:10px;color:#b00020;">
          Alerte sécurité
        </div>

        <div style="font-size:14px;line-height:1.5;color:#333;">
          Bonjour{{#if identity.inetOrgPerson.displayName}} {{identity.inetOrgPerson.displayName}}{{/if}},
          <br /><br />
          Un contrôle de sécurité indique que votre mot de passe apparaît dans des fuites connues.
          {{#if hibpCount}}
            Nombre d’occurrences observées : <b>{{hibpCount}}</b>.
          {{/if}}
        </div>

        <div style="margin-top:16px;padding:12px;background:#fff0f0;border:1px solid #ffd2d2;border-radius:8px;font-size:13px;color:#333;">
          Recommandation : changez votre mot de passe dès que possible.
        </div>

        {{#if url}}
          <div style="margin-top:18px;">
            <a href="{{url}}" style="display:inline-block;background:#b00020;color:#fff;text-decoration:none;padding:10px 14px;border-radius:8px;font-size:14px;">
              Changer mon mot de passe
            </a>
          </div>
        {{/if}}

        <div style="margin-top:18px;font-size:12px;color:#666;">
          Ceci est une notification : votre accès n’est pas bloqué (sauf si une politique d’expiration est activée).
        </div>
      </div>
    </div>
  </body>
</html>

